#!/usr/bin/env bash

## Zellij
#
alias zetwopanes="zellij --layout two_panes"
alias zedap="zellij --layout devaspros"

## Git Pull Requests
#
# Aliases para los PRs
#
# Solo falta pasarle el mensaje entre comillas.
alias piar="hub pull-request -c -b main -m"
alias draftpiar="hub pull-request -c -d -b main -m"

## Claude
#
alias claudio="claude"
